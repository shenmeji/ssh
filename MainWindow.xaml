<Window x:Class="SimpleSshClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleSshClient"
        mc:Ignorable="d"
        Title="什么机" Height="600" Width="1000"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button x:Name="BtnManageConnections" Content="管理连接" Margin="5" Padding="10,5" Click="BtnManageConnections_Click"/>
            <Button x:Name="BtnConnectionStats" Content="连接状态" Margin="5" Padding="10,5" Click="BtnConnectionStats_Click"/>
            <Separator/>
            <Button x:Name="BtnSftpBrowser" Content="SFTP文件浏览器" Margin="5" Padding="10,5" Click="BtnSftpBrowser_Click"/>
            <Separator/>
            <Button x:Name="BtnQuickCommand" Content="快速命令" Margin="5" Padding="10,5" Click="BtnQuickCommand_Click"/>
            <Separator/>
            <Button x:Name="BtnSettings" Content="设置" Margin="5" Padding="10,5" Click="BtnSettings_Click"/>
        </ToolBar>

        <StatusBar Grid.Row="1" Margin="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}"/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnectionStatusIndicator" Width="10" Height="10" Fill="Red" Margin="0,0,5,0"/>
                    <TextBlock x:Name="ConnectionInfoText" Text="未连接"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}"/>
            <StatusBarItem>
                <TextBlock x:Name="ConnectionTimeText" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <TabControl x:Name="TabControl" Grid.Row="2" Margin="5" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="欢迎" IsEnabled="False">
                <Grid Background="#F5F5F5">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" TextBlock.TextAlignment="Center" Margin="20">
                        <TextBlock Text="什么机 又一个ssh客户端" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock Text="当前无活动连接" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="请使用以下功能开始：" FontSize="14" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Button Content="管理连接" Margin="5" Padding="10,5" Click="BtnManageConnections_Click"/>
                            <Button Content="SFTP浏览器" Margin="5" Padding="10,5" Click="BtnSftpBrowser_Click"/>
                        </StackPanel>
                        <TextBlock Text="或使用顶部工具栏的按钮访问其他功能" FontSize="12" Margin="0,20,0,0" Foreground="#666666"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
