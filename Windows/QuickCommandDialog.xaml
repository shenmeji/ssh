<Window x:Class="SimpleSshClient.Windows.QuickCommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="快速命令" 
        Height="500" Width="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="常用命令:" Margin="0,0,0,10" FontWeight="SemiBold"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="QuickCommandsListBox" Grid.Column="0" Margin="0,0,10,0" 
                     SelectionChanged="QuickCommandsListBox_SelectionChanged"
                     MouseDoubleClick="QuickCommandsListBox_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SortOrder}" Width="30" Foreground="Gray"/>
                                <TextBlock Text="{Binding Name}" Margin="5,0,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="35,2,0,0">
                                <TextBlock Text="执行:" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding ExecuteCount}" Foreground="Gray" FontSize="10" Margin="3,0,10,0"/>
                                <TextBlock Text="上次:" Foreground="Gray" FontSize="10"/>
                                <TextBlock Text="{Binding LastExecutedAt, StringFormat='yyyy-MM-dd HH:mm'}" Foreground="Gray" FontSize="10" Margin="3,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Width="80">
                <Button x:Name="AddButton" Content="添加" Margin="0,0,0,5" Padding="10,5" Click="AddButton_Click"/>
                <Button x:Name="EditButton" Content="编辑" Margin="0,0,0,5" Padding="10,5" Click="EditButton_Click" IsEnabled="False"/>
                <Button x:Name="DeleteButton" Content="删除" Margin="0,0,0,20" Padding="10,5" Click="DeleteButton_Click" IsEnabled="False"/>
                <Separator Margin="0,0,0,10"/>
                <Button x:Name="ExportButton" Content="导出" Margin="0,0,0,5" Padding="10,5" Click="ExportButton_Click"/>
                <Button x:Name="ImportButton" Content="导入" Margin="0,0,0,5" Padding="10,5" Click="ImportButton_Click"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="命令:" Margin="0,10,0,5"/>
        <TextBox x:Name="CommandTextBox" Grid.Row="3" Margin="0,0,0,10" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ExecuteButton" Content="执行" Margin="0,0,10,0" Padding="20,8" IsDefault="True" Click="ExecuteButton_Click"/>
            <Button x:Name="CancelButton" Content="取消" Padding="20,8" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
