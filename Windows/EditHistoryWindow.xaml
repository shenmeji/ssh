<Window x:Class="SimpleSshClient.Windows.EditHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="编辑记录" 
        Height="400" Width="600"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView x:Name="HistoryListView" Grid.Row="0" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="文件名" Width="150" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="修改时间" Width="150" DisplayMemberBinding="{Binding EditTime}"/>
                    <GridViewColumn Header="路径" Width="150" DisplayMemberBinding="{Binding Path}"/>
                    <GridViewColumn Header="连接标识" Width="120" DisplayMemberBinding="{Binding ConnectionId}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ClearButton" Content="清空记录" Margin="0,0,10,0" Click="ClearButton_Click"/>
            <Button x:Name="CloseButton" Content="关闭" Padding="20,8" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>