<Window x:Class="SimpleSshClient.Windows.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="选择颜色"
        Height="400" Width="500"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="选择颜色" FontWeight="SemiBold" Margin="0,0,0,20"/>
            
            <!-- 颜色预览 -->
            <Rectangle x:Name="ColorPreview" Width="200" Height="100" Stroke="Black" StrokeThickness="1" Margin="0,0,0,30"/>
            
            <!-- RGB滑块 -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="红色: " Width="50" VerticalAlignment="Center"/>
                    <Slider x:Name="RedSlider" Minimum="0" Maximum="255" Value="255" Width="200" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="RedValue" Text="255" Width="40" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="绿色: " Width="50" VerticalAlignment="Center"/>
                    <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="255" Width="200" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="GreenValue" Text="255" Width="40" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="蓝色: " Width="50" VerticalAlignment="Center"/>
                    <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="255" Width="200" ValueChanged="Slider_ValueChanged"/>
                    <TextBlock x:Name="BlueValue" Text="255" Width="40" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 颜色代码 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="颜色代码: " Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ColorHex" Margin="0,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="OkButton" Content="确定" Margin="0,0,10,0" Padding="20,8" IsDefault="True" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="取消" Padding="20,8" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>