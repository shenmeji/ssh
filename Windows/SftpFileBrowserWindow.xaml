<Window x:Class="SimpleSshClient.Windows.SftpFileBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SFTP文件浏览器"
        Height="600" Width="800"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="4,2,4,2"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 第一行：连接选择、下载管理器、编辑历史 -->
        <ToolBar Grid.Row="1" Margin="0,0,0,5">
            <Separator/>
            <ComboBox x:Name="ConnectionComboBox" Width="150" SelectionChanged="ConnectionComboBox_SelectionChanged" Margin="0,0,10,0"/>
            <Button x:Name="BtnDownloadManager" Content="下载记录" Click="BtnDownloadManager_Click"/>
            <Button x:Name="BtnUploadManager" Content="上传记录" Click="BtnUploadManager_Click"/>
            <Button x:Name="BtnEditHistory" Content="编辑记录" Click="BtnEditHistory_Click"/>
        </ToolBar>

        <!-- 路径栏 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnRefresh" Grid.Column="0" Content="刷新" Click="BtnRefresh_Click" ToolTip="刷新文件列表" Margin="0,0,10,0"/>
            <Button x:Name="BtnBack" Grid.Column="1" Content="向上一级" Click="BtnBack_Click" ToolTip="向上一级" Margin="0,0,10,0"/>
            <TextBox x:Name="PathTextBox" Grid.Column="2" IsReadOnly="False" KeyDown="PathTextBox_KeyDown"/>
        </Grid>

        <!-- 第二行：文件操作按钮 -->
        <ToolBar Grid.Row="3" Margin="0,0,0,10">
                <Button x:Name="BtnUpload" Content="上传文件" Click="BtnUpload_Click"/>
                <Button x:Name="BtnNewFolder" Content="新建文件夹" Click="BtnNewFolder_Click"/>
                <Button x:Name="BtnNewFile" Content="新建文件" Click="BtnNewFile_Click"/>
                <Button x:Name="BtnDownload" Content="下载" Click="BtnDownload_Click"/>
                <Button x:Name="BtnEdit" Content="查看编辑" Click="BtnEdit_Click"/>
                <Button x:Name="BtnRename" Content="重命名" Click="BtnRename_Click"/>
                <Button x:Name="BtnCopy" Content="复制" Click="BtnCopy_Click"/>
                <Button x:Name="BtnCut" Content="剪切" Click="BtnCut_Click"/>
                <Button x:Name="BtnPaste" Content="粘贴" Click="BtnPaste_Click"/>
                <Button x:Name="BtnDelete" Content="删除" Click="BtnDelete_Click"/>
            </ToolBar>

        <!-- 文件列表 -->
        <ListView x:Name="FilesListView" Grid.Row="4" SelectionChanged="FilesListView_SelectionChanged" MouseDoubleClick="FilesListView_MouseDoubleClick">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="上传" Click="ContextMenu_Upload_Click"/>
                    <Separator/>
                    <MenuItem Header="新建文件夹" Click="ContextMenu_NewFolder_Click"/>
                    <MenuItem Header="新建文件" Click="ContextMenu_NewFile_Click"/>
                    <MenuItem Header="查看编辑" Click="ContextMenu_Edit_Click"/>
                    <MenuItem Header="重命名" Click="ContextMenu_Rename_Click"/>
                    <MenuItem Header="复制" Click="ContextMenu_Copy_Click"/>
                    <MenuItem Header="剪切" Click="ContextMenu_Cut_Click"/>
                    <MenuItem Header="粘贴" Click="ContextMenu_Paste_Click"/>
                    <MenuItem Header="下载" Click="ContextMenu_Download_Click"/>
                    <MenuItem Header="删除" Click="ContextMenu_Delete_Click"/>
                    <Separator/>
                    <MenuItem Header="刷新" Click="ContextMenu_Refresh_Click"/>
                    <MenuItem Header="向上一级" Click="ContextMenu_Back_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="名称" Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="类型" Width="100" DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="大小" Width="100" DisplayMemberBinding="{Binding Size}"/>
                    <GridViewColumn Header="修改时间" Width="150" DisplayMemberBinding="{Binding LastWriteTime}"/>
                    <GridViewColumn Header="权限" Width="100" DisplayMemberBinding="{Binding Permissions}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="5" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem Width="200">
                <ProgressBar x:Name="TransferProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="TransferProgressText" Text="" Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>