<Window x:Class="SimpleSshClient.Windows.CommandHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="发送记录"
        Height="500" Width="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="本次连接的命令记录:" Margin="0,0,0,10" FontWeight="SemiBold"/>

        <ListBox x:Name="CommandHistoryListBox" Grid.Row="1" Margin="0,0,0,10"
                 SelectionChanged="CommandHistoryListBox_SelectionChanged" 
                 MouseDoubleClick="CommandHistoryListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="命令:" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="{Binding}" Margin="10,2,0,5" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2" Text="命令:" Margin="0,10,0,5"/>
        <TextBox x:Name="CommandTextBox" Grid.Row="3" Margin="0,0,0,10" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ExecuteButton" Content="执行" Margin="0,0,10,0" Padding="20,8" IsDefault="True" Click="ExecuteButton_Click"/>
            <Button x:Name="SaveButton" Content="保存" Margin="0,0,10,0" Padding="20,8" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="取消" Padding="20,8" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>