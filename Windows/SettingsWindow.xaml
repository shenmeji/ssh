<Window x:Class="SimpleSshClient.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置"
        Height="400"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="外观设置" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Button x:Name="BtnTheme" Content="配色" Width="200" Height="30" Margin="0,0,0,10" Click="BtnTheme_Click"/>
            
            <TextBlock Text="系统设置" FontSize="14" FontWeight="SemiBold" Margin="0,20,0,10"/>
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnViewLogs" Content="查看日志" Width="200" Height="30" Margin="0,0,10,10" Click="BtnViewLogs_Click"/>
                <Button x:Name="BtnClearLogs" Content="清空日志" Width="200" Height="30" Margin="0,0,0,10" Click="BtnClearLogs_Click"/>
            </WrapPanel>
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnConnectionPoolSettings" Content="连接池设置" Width="200" Height="30" Margin="0,0,10,10" Click="BtnConnectionPoolSettings_Click"/>
                <Button x:Name="BtnSoftwareHome" Content="软件主页" Width="200" Height="30" Margin="0,0,0,10" Click="BtnSoftwareHome_Click"/>
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,20,0,0">
            <TextBlock x:Name="TbLastUpdate" Text="最后更新时间: " HorizontalAlignment="Center" FontSize="12" Foreground="Gray" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnClose" Content="关闭" Padding="20,8" IsCancel="True" Click="BtnClose_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
