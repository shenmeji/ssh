<Window x:Class="SimpleSshClient.Windows.ConnectionStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="连接状态"
        Height="400"
        Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="总SSH连接数: " FontWeight="Bold"/>
            <TextBlock x:Name="TotalConnectionsText" Text="0"/>
            <TextBlock Text="  |  总通道数: " FontWeight="Bold" Margin="10,0,0,0"/>
            <TextBlock x:Name="TotalChannelsText" Text="0"/>
        </StackPanel>
        
        <ListView x:Name="ConnectionsListView" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="连接标识" Width="250" DisplayMemberBinding="{Binding Key}"/>
                    <GridViewColumn Header="使用计数" Width="100" DisplayMemberBinding="{Binding UsageCount}"/>
                    <GridViewColumn Header="连接时间" Width="150" DisplayMemberBinding="{Binding ConnectTime}"/>
                    <GridViewColumn Header="最后使用" Width="150" DisplayMemberBinding="{Binding LastUsed}"/>
                    <GridViewColumn Header="状态" Width="100" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshButton" Content="刷新" Padding="10,5" Click="RefreshButton_Click"/>
            <Button x:Name="CloseButton" Content="关闭" Padding="10,5" Margin="10,0,0,0" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>