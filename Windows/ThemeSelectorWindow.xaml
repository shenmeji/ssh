<Window x:Class="SimpleSshClient.Windows.ThemeSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="颜色设置"
        Height="450" Width="600"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 背景色设置 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
            <TextBlock Text="背景色: " FontWeight="SemiBold" Width="80" VerticalAlignment="Center"/>
            <Rectangle x:Name="BackgroundColorPreview" Width="60" Height="40" Fill="{Binding Background}" Stroke="Black" StrokeThickness="1" Margin="0,0,20,0"/>
            <TextBox x:Name="BackgroundColorTextBox" Width="100" Text="{Binding Background, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 文字色设置 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
            <TextBlock Text="文字色: " FontWeight="SemiBold" Width="80" VerticalAlignment="Center"/>
            <Rectangle x:Name="ForegroundColorPreview" Width="60" Height="40" Fill="{Binding Foreground}" Stroke="Black" StrokeThickness="1" Margin="0,0,20,0"/>
            <TextBox x:Name="ForegroundColorTextBox" Width="100" Text="{Binding Foreground, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </StackPanel>



        <!-- 选择颜色设置 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
            <TextBlock Text="选择色: " FontWeight="SemiBold" Width="80" VerticalAlignment="Center"/>
            <Rectangle x:Name="SelectionColorPreview" Width="60" Height="40" Fill="{Binding Selection}" Stroke="Black" StrokeThickness="1" Margin="0,0,20,0"/>
            <TextBox x:Name="SelectionColorTextBox" Width="100" Text="{Binding Selection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 预览效果 -->
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="预览效果" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Border Grid.Row="1" Background="{Binding Background}" BorderBrush="Black" BorderThickness="1">
                <Grid>
                    <TextBlock Text="这是一段预览文本，用于显示主题效果" Foreground="{Binding Foreground}" Margin="10" VerticalAlignment="Center"/>
                    <Border Background="{Binding Selection}" Width="100" Height="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,40,0,0">
                        <TextBlock Text="选中文本" Foreground="{Binding Foreground}" Margin="2"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="ResetButton" Content="恢复默认" Margin="0,0,10,0" Padding="20,8" Click="ResetButton_Click"/>
            <Button x:Name="OkButton" Content="应用" Margin="0,0,10,0" Padding="20,8" IsDefault="True" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="取消" Padding="20,8" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>