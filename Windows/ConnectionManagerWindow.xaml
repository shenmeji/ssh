<Window x:Class="SimpleSshClient.Windows.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="连接管理" 
        Height="500" Width="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ConnectionsListBox" Grid.Column="0" DisplayMemberPath="Name" SelectionChanged="ConnectionsListBox_SelectionChanged" MouseDoubleClick="ConnectionsListBox_MouseDoubleClick"/>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Button x:Name="AddButton" Content="添加" Margin="0,0,0,5" Padding="20,8" Click="AddButton_Click"/>
                <Button x:Name="EditButton" Content="编辑" Margin="0,0,0,5" Padding="20,8" Click="EditButton_Click" IsEnabled="False"/>
                <Button x:Name="DeleteButton" Content="删除" Margin="0,0,0,20" Padding="20,8" Click="DeleteButton_Click" IsEnabled="False"/>
                <Separator Margin="0,0,0,10"/>
                <Button x:Name="ExportButton" Content="导出" Margin="0,0,0,5" Padding="20,8" Click="ExportButton_Click"/>
                <Button x:Name="ImportButton" Content="导入" Margin="0,0,0,5" Padding="20,8" Click="ImportButton_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="ConnectButton" Content="连接" Margin="0,0,10,0" Padding="20,8" IsDefault="True" Click="ConnectButton_Click" IsEnabled="False"/>
            <Button x:Name="CloseButton" Content="关闭" Padding="20,8" IsCancel="True" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
